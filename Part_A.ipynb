   "cell_type": "code",
   "source": [
    "df_ttl = df[['label', 'sttl', 'sbytes', 'dbytes']].dropna()\n",
    "df_ttl['sttl'] = df_ttl['sttl'].astype(int)\n",
    "\n",
    "df_ttl['ratio'] = df_ttl['sbytes'] / (df_ttl['dbytes'] + 1)\n",
    "\n",
    "def est_init(ttl):\n",
    "    if ttl <= 64:\n",
    "        return 64\n",
    "    elif ttl <= 128:\n",
    "        return 128\n",
    "    else:\n",
    "        return 255\n",
    "\n",
    "df_ttl['init_ttl'] = df_ttl['sttl'].apply(est_init)\n",
    "df_ttl['hops'] = df_ttl['init_ttl'] - df_ttl['sttl']\n",
    "\n",
    "def hop_group(h):\n",
    "    if h <= 5:\n",
    "        return \"close\"\n",
    "    elif h <= 15:\n",
    "        return \"mid\"\n",
    "    else:\n",
    "        return \"far\"\n",
    "\n",
    "df_ttl['hop_group'] = df_ttl['hops'].apply(hop_group)\n",
    "\n",
    "summary = df_ttl.groupby(['label','hop_group']).size().unstack(fill_value=0)\n",
    "print(summary)\n",
    "\n",
    "summary.T.plot(kind='bar', figsize=(7,4), color=['skyblue','salmon'])\n",
    "plt.title('')\n",
    "plt.ylabel('number of rows')\n",
    "plt.xlabel('estimate dist')\n",
    "plt.legend(['Regular (0)', 'Attack (1)'])\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "df_ttl.groupby(['hop_group','label'])['ratio'].mean().unstack().plot(\n",
    "    kind='bar', figsize=(7,4), color=['steelblue','salmon']\n",
    ")\n",
    "plt.title('Mean sbytes/dbytes ratio by hop_group and label')\n",
    "plt.ylabel('Mean ratio')\n",
    "plt.xlabel('Hop group')\n",
    "plt.legend(['Regular (0)', 'Attack (1)'])\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "plt.hist(df[df['label']==0]['sttl'], bins=50, alpha=0.6, label='Normal (0)')\n",
    "plt.hist(df[df['label']==1]['sttl'], bins=50, alpha=0.6, label='Attack (1)', color='red')\n",
    "plt.xlabel('Source TTL')\n",
    "plt.ylabel('Count')\n",
    "plt.title('TTL Distribution - Normal vs Attack')\n",
    "plt.legend()\n",
    "plt.show()\n"
   ],
